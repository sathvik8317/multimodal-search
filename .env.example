# Cohere API key: powers embedding, reranking, and ingestion.
COHERE_API_KEY=your-key-here

# Shared secret gating /search and /thumbnails. Required -- the server
# refuses to start without it. Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
MMSEARCH_API_KEY=your-own-shared-secret-here

# Optional. Comma-separated origins allowed by CORS. Defaults to the Vite
# dev server ports; only needed if you run the frontend somewhere else.
# MMSEARCH_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional. /search rate limit: max requests per window (seconds).
# MMSEARCH_RATE_LIMIT_MAX=20
# MMSEARCH_RATE_LIMIT_WINDOW=60

# Optional. dev | staging | prod. Only "dev" has behavior attached today
# (requires MMSEARCH_API_KEY at startup).
# MMSEARCH_ENV=dev
