# Cohere API key: powers image embedding, reranking, and ingestion.
COHERE_API_KEY=your-key-here

# OpenAI API key: powers table/code/caption-text embedding (see
# EMBEDDING_MIGRATION_PLAN.md). Required -- the query path is Cohere+OpenAI+FTS,
# not Cohere alone.
OPENAI_API_KEY=your-key-here

# Shared secret gating /search and /thumbnails. Required -- the server
# refuses to start without it. Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
MMSEARCH_API_KEY=your-own-shared-secret-here

# Optional. Comma-separated origins allowed by CORS. Defaults to the Vite
# dev server ports; only needed if you run the frontend somewhere else.
# MMSEARCH_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional. /search rate limit: max requests per window (seconds).
# MMSEARCH_RATE_LIMIT_MAX=20
# MMSEARCH_RATE_LIMIT_WINDOW=60

# Optional. dev | staging | prod. Only "dev" has behavior attached today
# (requires MMSEARCH_API_KEY at startup). Leave unset on Render too -- see
# DEPLOYMENT_PLAN.md #4 for why "prod" is a worse failure mode here, not a
# better one.
# MMSEARCH_ENV=dev

# Optional. /upload rate limit: max requests per window (seconds). Kept
# separate from MMSEARCH_RATE_LIMIT_MAX/WINDOW above -- ingestion is far more
# expensive per request than a search.
# MMSEARCH_UPLOAD_RATE_LIMIT_MAX=5
# MMSEARCH_UPLOAD_RATE_LIMIT_WINDOW=60

# Optional. Points LanceDB at Cloudflare R2 instead of the local committed
# data/lancedb -- needed for the deployed /upload endpoint to persist writes
# (Render has no disk). Unset = local dev is unchanged. See UPLOAD_PLAN.md
# and DEPLOYMENT_PLAN.md's "/upload and Cloudflare R2" addendum.
# MMSEARCH_LANCEDB_URI=s3://your-bucket/lancedb
# MMSEARCH_R2_BUCKET=your-bucket

# Optional, required alongside MMSEARCH_LANCEDB_URI above. Standard AWS SDK
# names -- shared by LanceDB's object store and storage/r2.py's boto3 client.
# AWS_ACCESS_KEY_ID=your-r2-token-key
# AWS_SECRET_ACCESS_KEY=your-r2-token-secret
# AWS_ENDPOINT_URL=https://your-accountid.r2.cloudflarestorage.com
# AWS_REGION=auto

# Deployment: these same variables are set in the Render dashboard
# (Environment tab), not in a .env file on the server. See DEPLOYMENT_PLAN.md.
